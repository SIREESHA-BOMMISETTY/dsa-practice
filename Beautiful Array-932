class Solution:
    def beautifulArray(self, n: int) -> List[int]:
        res =[]
        res.append(1)
        while len(res) <= n:
            temp = []
            for i in res:
                if 2*i-1 <= n:
                    temp.append(2*i-1)
            for i in res:
                if 2*i <= n:
                    temp.append(2*i)        
            res=temp
        return res    
